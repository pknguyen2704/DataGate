TZ=Asia/Ho_Chi_Minh

# ── PostgreSQL source ──────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgrespassword
SOURCE_TABLE=public.yellow_tripdata

# ── Scheduling & Batch ────────────────
SCHEDULE_INTERVAL_SECONDS=30
BATCH_SIZE=50000

# ── MinIO (Medallion structure inside bucket) ────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=miniopassword
MINIO_BUCKET=lakehouse

# ── Iceberg REST Catalog ───────────────
ICEBERG_REST_URI=http://localhost:8181
ICEBERG_NAMESPACE=bronze
TARGET_TABLE=bronze.yellow_tripdata

# ── Runtime directories ────────────────
CHECKPOINT_DIR=auto_loader/checkpoint
CHECKPOINT_DB_NAME=checkpoint.db
