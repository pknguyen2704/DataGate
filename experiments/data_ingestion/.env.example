TZ=Asia/Ho_Chi_Minh

# ── PostgreSQL source ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgrespassword
SOURCE_TABLE=public.telecom_cdr

# ── Scheduling ─────────────────────────────────────────────────────────────────
SCHEDULE_INTERVAL_SECONDS=10
BATCH_SIZE=1000

# ── MinIO (S3-compatible object store) ────────────────────────────────────────
# When running inside Docker on the same network, use the container hostname:
#   MINIO_ENDPOINT=http://minio:9000
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=miniopassword
MINIO_BUCKET=lakehouse
MINIO_BRONZE_PREFIX=bronze/telecom_cdr

# ── Iceberg REST Catalog ───────────────────────────────────────────────────────
# When running inside Docker on the same network, use the container hostname:
#   ICEBERG_REST_URI=http://iceberg-rest:8181
ICEBERG_REST_URI=http://localhost:8181
ICEBERG_NAMESPACE=bronze
TARGET_TABLE=bronze.telecom_cdr

# ── Runtime directories ────────────────────────────────────────────────────────
REJECTED_DIR=auto_loader/rejected
CHECKPOINT_DIR=auto_loader/checkpoint
LOG_DIR=auto_loader/logs
CHECKPOINT_DB_NAME=checkpoint.db
