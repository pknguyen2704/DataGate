TZ=Asia/Ho_Chi_Minh
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=miniopassword
AWS_REGION=us-east-1
CATALOG_WAREHOUSE=s3://lakehouse/

# FileIO
CATALOG_IO__IMPL=org.apache.iceberg.aws.s3.S3FileIO

# --- Option 1 keys (some images use these)
CATALOG_S3_ENDPOINT=http://minio:9000
CATALOG_S3_PATH_STYLE_ACCESS=true

# --- Option 2 keys (some images use these)
CATALOG_IO__S3__ENDPOINT=http://minio:9000
CATALOG_IO__S3__PATH_STYLE_ACCESS=true

# Catalog backend (JDBC)
CATALOG_CATALOG__IMPL=org.apache.iceberg.jdbc.JdbcCatalog
CATALOG_URI=jdbc:postgresql://catalog-db:5432/iceberg
CATALOG_JDBC_USER=admin
CATALOG_JDBC_PASSWORD=catalogpassword

POSTGRES_USER=admin
POSTGRES_PASSWORD=catalogpassword
POSTGRES_DB=iceberg