TZ=Asia/Ho_Chi_Minh

# Iceberg REST Catalog settings
CATALOG_URI=jdbc:sqlite:/var/lib/iceberg/iceberg_catalog.db
CATALOG_WAREHOUSE=s3://lakehouse/
CATALOG_IO__IMPL=org.apache.iceberg.aws.s3.S3FileIO

# S3 / MinIO Configuration
CATALOG_S3_ENDPOINT=http://minio:9000
CATALOG_S3_REGION=us-east-1
CATALOG_S3_ACCESS_KEY_ID=admin
CATALOG_S3_SECRET_ACCESS_KEY=miniopassword
CATALOG_S3_PATH_STYLE_ACCESS=true

# Redundant variants for compatibility with different image versions
CATALOG_S3__ENDPOINT=http://minio:9000
CATALOG_S3__REGION=us-east-1
CATALOG_S3__PATH__STYLE__ACCESS=true

# Standard AWS environment variables (fallback)
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=miniopassword
AWS_REGION=us-east-1
AWS_EC2_METADATA_DISABLED=true
