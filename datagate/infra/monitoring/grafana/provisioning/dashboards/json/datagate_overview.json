          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  column_name AS \"Column\",\n  MAX(CASE WHEN metric_name = 'Completeness' THEN metric_value END) AS \"Completeness\",\n  MAX(CASE WHEN metric_name = 'Distinctness' THEN metric_value END) AS \"Distinctness\",\n  MAX(CASE WHEN metric_name = 'ApproxCountDistinct' THEN metric_value END) AS \"Approx Distinct\",\n  MAX(CASE WHEN metric_name = 'Minimum' THEN metric_value END) AS \"Min\",\n  MAX(CASE WHEN metric_name = 'Maximum' THEN metric_value END) AS \"Max\",\n  MAX(CASE WHEN metric_name = 'Mean' THEN metric_value END) AS \"Mean\",\n  MAX(CASE WHEN metric_name = 'StandardDeviation' THEN metric_value END) AS \"Std Dev\",\n  MAX(collected_at) AS \"Collected At\"\nFROM analyzer_results\nWHERE table_id = NULLIF('${table_id}','')::uuid\n  AND $__timeFilter(collected_at)\nGROUP BY column_name\nORDER BY column_name;",
